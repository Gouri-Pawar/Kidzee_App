<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimary"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    tools:context=".VideosActivity">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="250dp"
        android:layout_gravity="left">

        <pl.droidsonroids.gif.GifImageView
            android:layout_width="363dp"
            android:layout_height="270dp"
            android:layout_marginLeft="11dp"
            android:layout_marginRight="10dp"
            android:layout_marginTop="10dp"
            android:src="@drawable/learn_anim" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/videos_english_letters_btn"
            style="@style/textStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/transparent_background"
            android:maxWidth="0dp"
            android:text="@string/english_letters"
            android:textSize="@dimen/small_text_size" />

        <Button
            android:id="@+id/videos_english_numbers_btn"
            style="@style/textStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/button_style"
            android:maxWidth="0dp"
            android:layout_marginLeft="40dp"
            android:layout_marginBottom="10dp"
            android:text="@string/english_numbers"
            android:textSize="@dimen/small_text_size" />
</LinearLayout>

    <VideoView
        android:id="@+id/videos_video_view"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>